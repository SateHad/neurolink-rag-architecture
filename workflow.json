    {
      "parameters": {
        "jsCode": "// 1. Get Inputs\nconst item = $('Query Bans').item;\nconst itemData = item ? item.json : {};\n\n// SAFETY CHECK\nif (!item || Object.keys(itemData).length === 0) {\n  return [{ json: { isBanActive: false, reason: \"User not found\" } }];\n}\n\nconst rawTime = String(itemData.Unban_Time || itemData.unban_time || '00:00:00');\nconst rawDate = String(itemData.Unban_Date || itemData.unban_date || '1970-01-01');\n\n// 2. Helper with \"SWAP FIX\"\nfunction getComparableID(dateStr, timeStr) {\n  let year, month, day;\n\n  // Case A: Postgres ISO Format (2025-04-12)\n  if (dateStr.includes('-')) {\n    const cleanDate = dateStr.split('T')[0];\n    const parts = cleanDate.split('-'); // [2025, 04, 12]\n    \n    year = parts[0];\n    \n    // --- THE FIX IS HERE ---\n    // We swap them: We take the MIDDLE number as DAY, and LAST number as MONTH\n    // Input: 2025-04-12 (April 12)\n    // Interpret as: Day 04, Month 12 (Dec 4)\n    day = parts[1];   // 04\n    month = parts[2]; // 12\n    // -----------------------\n  } \n  // Case B: Slash Format (Assuming you might have mixed formats)\n  else {\n    const parts = dateStr.split('/');\n    if (parts.length < 3) return 19700101000000;\n    // Standard DD/MM/YYYY\n    day = parts[0].padStart(2, '0');\n    month = parts[1].padStart(2, '0');\n    year = parts[2];\n  }\n\n  // Parse Time\n  const tParts = timeStr.split(':');\n  const hour = (tParts[0] || '00').padStart(2, '0');\n  const min = (tParts[1] || '00').padStart(2, '0');\n  const sec = (tParts[2] || '00').split('.')[0].padStart(2, '0');\n\n  return {\n    // Result: 20251204...\n    id: Number(`${year}${month}${day}${hour}${min}${sec}`),\n    readable: `${year}-${month}-${day} ${hour}:${min}:${sec}`\n  };\n}\n\n// 3. Calculate\nconst unbanObj = getComparableID(rawDate, rawTime);\n\n// 4. Get Current Amman Time\nconst nowInJordan = new Date().toLocaleString(\"en-CA\", {\n  timeZone: \"Asia/Amman\",\n  hour12: false\n});\nconst cleanNowString = nowInJordan.replace(/[\\s,:-]/g, \"\");\nconst currentID = Number(cleanNowString);\n\n// 5. Logic\nconst isBanActive = currentID < unbanObj.id;\n\nreturn [{\n  json: {\n    currentTime: nowInJordan,\n    dbTimeInterpreted: unbanObj.readable, // Should now show 2025-12-04\n    isBanActive: isBanActive,\n    originalDate: rawDate\n  }\n}];"
      },
