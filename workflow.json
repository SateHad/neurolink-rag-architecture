      "parameters": {
        "jsCode": "// 1. Establish the current time in Jordan\nconst dateString = new Date().toLocaleString(\"en-US\", { timeZone: \"Asia/Amman\" });\nconst banObj = new Date(dateString);\n\n/** * HELPER FUNCTION: Formats date to YYYY-MM-DD for Database compatibility\n * Using manual slicing to avoid locale-specific surprises\n */\nconst formatDateForDB = (date) => {\n  const yyyy = date.getFullYear();\n  const mm = String(date.getMonth() + 1).padStart(2, '0');\n  const dd = String(date.getDate()).padStart(2, '0');\n  return `${yyyy}-${mm}-${dd}`;\n};\n\n// 2. Format Ban Date and Time\nconst banDate = formatDateForDB(banObj); // Outputs: YYYY-MM-DD\nconst banTime = banObj.toLocaleTimeString(\"en-GB\", { hour12: false });\n\n// 3. Calculate Unban Time (Add 2 hours)\nconst unbanObj = new Date(banObj);\nunbanObj.setHours(unbanObj.getHours() + 2);\n\n// 4. Format Unban Date and Time\nconst unbanDate = formatDateForDB(unbanObj); // Outputs: YYYY-MM-DD\nconst unbanTime = unbanObj.toLocaleTimeString(\"en-GB\", { hour12: false });\n\nreturn [{ \n  banDate: banDate,\n  banTime: banTime,\n  unbanDate: unbanDate,\n  unbanTime: unbanTime,\n  // Sending these as separate \"Time2HourAhead\" or \"Time\" fields as seen in your screenshot:\n  Time: banTime,\n  Time2HourAhead: unbanTime\n}];"
      },
