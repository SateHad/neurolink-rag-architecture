    {
      "parameters": {
        "jsCode": "// 1. Get the raw text from the AI Agent\n// We use your existing path, but removed .toLowerCase() because the tag is case-sensitive\nconst rawText = $input.first().json.output?.[0]?.content?.[0]?.text || $input.first().json.output || \"\";\n\n// 2. Check if the specific tag exists (returns true/false)\nconst wantsHuman = rawText.includes(\"###HUMAN_HANDOFF###\");\n\n// 3. Create a clean version of the message (removes the tag)\n// Use this 'clean_response' in your Messenger/Instagram nodes later!\nconst cleanResponse = rawText.replace(\"###HUMAN_HANDOFF###\", \"\").trim();\n\n// 4. Return the boolean exactly as before so your IF node works\nreturn [{\n    json: { \n        wantsHuman: wantsHuman,\n        output: cleanResponse \n    }\n}];"
      },
